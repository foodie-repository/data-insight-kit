{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://data-insight-kit/schemas/external_adapter_plan.schema.json",
  "title": "external_adapter_plan",
  "description": "guided intake의 external_adapters 선택값을 core pipeline stage에 전달하는 orchestration 계약.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "created_at",
    "status",
    "mode",
    "selected_categories",
    "available_categories",
    "unavailable_categories",
    "interpretation_guards",
    "registry_ref",
    "manifest_paths",
    "category_contracts",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "enum": [
        "data-insight-kit.external_adapter_plan.v1",
        "visualize-kit.external_adapter_plan.v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": ["none", "selected"]
    },
    "source_intake_path": {
      "type": ["string", "null"]
    },
    "mode": {
      "enum": ["ask_user_selected", "auto_recommended", "none"]
    },
    "selected_categories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/category"
      }
    },
    "available_categories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/category"
      }
    },
    "unavailable_categories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/category"
      }
    },
    "interpretation_guards": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "registry_ref": {
      "type": "string",
      "minLength": 1
    },
    "manifest_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "category_contracts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/category_contract"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "category": {
      "enum": [
        "population",
        "foot_traffic",
        "rent",
        "sales",
        "business_dynamics",
        "area",
        "competition",
        "mobility",
        "custom"
      ]
    },
    "category_contract": {
      "type": "object",
      "required": [
        "category",
        "metric_layers",
        "meaning",
        "allowed_uses",
        "prohibited_interpretations"
      ],
      "additionalProperties": false,
      "properties": {
        "category": {
          "$ref": "#/$defs/category"
        },
        "metric_layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["demand", "cost", "performance", "spatial", "competition", "context", "coverage"]
          }
        },
        "meaning": {
          "type": "string",
          "minLength": 1
        },
        "allowed_uses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prohibited_interpretations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
